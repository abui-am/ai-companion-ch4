DEVICE_TOKEN=
OPENAI_API_KEY=

# Pipeline v1 (stable) — see docs/STABLE_V1.md
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=verse

# TTS: openai (Realtime audio) or cartesia (Realtime text → Cartesia Sonic)
TTS_PROVIDER=openai
# CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02
# CARTESIA_MODEL_ID=sonic-3.5

# Web search (OpenAI Responses API) — enabled by default
WEB_SEARCH_ENABLED=true
# OPENAI_SEARCH_MODEL=gpt-4o-mini

# Optional: default TestClient WSS URL
