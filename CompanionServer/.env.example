DEVICE_TOKEN=
OPENAI_API_KEY=

# Pipeline v1 (stable) — see docs/STABLE_V1.md
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_VOICE=verse

# TTS: openai (Realtime audio) or cartesia (Realtime text → Cartesia Sonic)
TTS_PROVIDER=openai
# CARTESIA_API_KEY=
# CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02
# CARTESIA_MODEL_ID=sonic-3.5

# Response language: English, Indonesian, Spanish, etc. Use "auto" to match the user's language.
COMPANION_RESPONSE_LANGUAGE=English

# IANA timezone for task/calendar times ("tomorrow at 3pm" is interpreted in this zone).
# Defaults to the server's local timezone if unset.
COMPANION_TIMEZONE=Asia/Jakarta

# Web search (OpenAI Responses API) — enabled by default
WEB_SEARCH_ENABLED=true
# OPENAI_SEARCH_MODEL=gpt-4o-mini

# Embeddings for AI memory (pgvector-backed `memory` tool)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: default TestClient WSS URL

# Postgres (matches CompanionServer/docker-compose.yaml defaults)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/companion
